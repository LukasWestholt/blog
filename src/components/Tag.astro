---
export interface Props {
	tag: string
}
const { tag } = Astro.props

const currentPath = Astro.url.pathname
const isEnglish = currentPath.startsWith('/en/') || currentPath === '/en'
const tagSlug = tag.toLowerCase().replace(/\s+/g, '-')
const href = isEnglish ? `/en/tags/${tagSlug}/` : `/tags/${tagSlug}/`
---

<a href={href} aria-label={tag}>
	<span
		class='bg-indigo-600 font-semibold text-white dark:bg-indigo-900 dark:text-white shadow text-sm w-fit px-2 py-1 md:px-5 md:py-2 rounded-full'
	>
		{tag ?? 'Blog Tag'}
	</span>
</a>
