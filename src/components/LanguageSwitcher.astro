---
import { getCollection } from 'astro:content'

const currentPath = Astro.url.pathname

const isEnglish = currentPath.startsWith('/en/') || currentPath === '/en'

let targetUrl = '/'
let showSwitcher = true
let hasTranslation = true

const isPostPage = currentPath.match(/^\/(en\/)?post\//)

if (isPostPage) {
	// Wir sind auf einer Blogpost-Seite
	// Basis-Slug extrahieren (z.B. "calanyze" aus "/en/post/calanyze/")
	const baseSlug = currentPath.replace(/^\/(en\/)?post\//, '').replace(/\/$/, '')

	// Den Slug für die Datenbank-Abfrage zusammenbauen
	const targetCollectionSlug = isEnglish ? baseSlug : `en/${baseSlug}`

	// Prüfen, ob das Gegenstück auch wirklich existiert
	const allPosts = await getCollection('blog')
	hasTranslation = allPosts.some((post) => post.slug === targetCollectionSlug)

	// Neue URL bauen
	if (hasTranslation) {
		targetUrl = isEnglish ? `/post/${baseSlug}/` : `/en/post/${baseSlug}/`
	} else {
		targetUrl = '#'
	}
} else {
	// Für alle anderen Seiten (Kategorien, Tags, Startseite) erlauben wir den Wechsel,
	// da deine Post-Utils bei fehlenden Inhalten automatisch Fallbacks liefern!
	if (isEnglish) {
		targetUrl = currentPath.replace(/^\/en/, '') || '/'
	} else {
		targetUrl = currentPath === '/' ? '/en/' : `/en${currentPath}`
	}
}
---

{
	showSwitcher && (
		<div class='flex justify-end w-full'>
			{hasTranslation ? (
				<a
					href={targetUrl}
					class='inline-flex items-center gap-2 px-4 py-2 text-sm font-medium border border-neutral-200 dark:border-neutral-700 rounded-lg hover:bg-neutral-100 dark:hover:bg-neutral-800 transition-colors'
				>
					{isEnglish ? '🇩🇪 Auf Deutsch lesen' : '🇬🇧 Read in English'}
				</a>
			) : (
				<span class='inline-flex items-center gap-2 px-4 py-2 text-sm font-medium border border-neutral-200 dark:border-neutral-700 rounded-lg text-neutral-400 dark:text-neutral-500 cursor-not-allowed select-none'>
					🚫 Nicht übersetzt
				</span>
			)}
		</div>
	)
}
